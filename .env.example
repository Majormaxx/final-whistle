# Required
PRIVATE_KEY=0x...
JSON_API_AGENT_ID=

# Verification (forge verify-contract)
SOMNIASCAN_API_KEY=

# Optional — defaults to deployer if unset
MULTISIG_0=
MULTISIG_1=
MULTISIG_2=

# Optional — defaults to 0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
AGENT_PLATFORM=

# ── Bot (fill in after deployment) ────────────────────────────────────────────
BOT_PRIVATE_KEY=0x...         # deployer/owner key — must match PRIVATE_KEY above
FACTORY_ADDRESS=              # MarketFactory address from deploy
RESOLVER_ADDRESS=             # ResolverAgent address from deploy
MATCH_MARKET_ADDRESS=         # specific match market to trade
KICKOFF_TIMESTAMP=            # unix seconds, e.g. 1749330000
FIXTURE_ID=                   # api-sports.io fixture ID, e.g. 1234567
SPORTS_API_KEY=               # api-sports.io API key (used by bot to poll — not sent on-chain)
FIXTURE_API_URL=              # URL Somnia Agents will call, e.g. https://v3.football.api-sports.io/fixtures?id=1234567

# Optional bot tuning
RPC_URL=                      # defaults to https://dream-rpc.somnia.network
BET_SIZE_WEI=                 # defaults to 5000000000000000 (0.005 STT)
POLL_INTERVAL_MS=             # defaults to 30000 (30s)
